# code_graph: cache + manifest are local incremental-build state.
# graph.json + GRAPH_REPORT.md + _meta.json are the team-shareable
# outputs (commit those if you want collaborators to use them).
graphify-out/cache/
graphify-out/manifest.json
graphify-out/.code-graph-build.lock
