#!/usr/bin/env sh
# claude-hooks-daemon — POSIX entry point for the long-lived hook executor.
#
# Usage (foreground, blocks until SIGINT/SIGTERM):
#     claude-hooks-daemon [--host 127.0.0.1] [--port 47018]
#
# When running, the bin/claude-hook shim sends each hook event to this
# process over an HMAC-authenticated TCP localhost socket instead of
# spinning up a fresh Python interpreter — saves ~150-300 ms per hook.
#
# The daemon is OPTIONAL. Installs without it work exactly as before;
# the client's connect-refused error makes claude-hook fall back to
# in-process dispatch automatically.
#
# Autostart helpers (systemd / launchd / Windows Task Scheduler) are
# generated by install.py when the user opts in.

HERE="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$HERE/.." && pwd)"

. "$HERE/_resolve_python.sh"

if [ -z "$PY" ]; then
    echo "claude-hooks-daemon: no python found" >&2
    exit 1
fi

exec "$PY" -m claude_hooks.daemon "$@"
