#!/usr/bin/env sh
# claude-hook — POSIX entry point for claude-hooks
#
# Usage:
#     claude-hook <EventName>
#
# Reads the hook event JSON from stdin, dispatches to the matching handler,
# and writes any response to stdout. Exits 0 on every code path so a broken
# hook never blocks Claude Code.
#
# This is a thin shim — all logic lives in run.py / claude_hooks/.

HERE="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$HERE/.." && pwd)"

# Prefer the conda env's Python if the env exists, then fall back to
# system python3 / python.  The conda env is installed by setup and
# contains all optional deps (pytest, psycopg, sqlite-vec, …).
CONDA_PY="/root/anaconda3/envs/claude-hooks/bin/python"
if [ -x "$CONDA_PY" ]; then
    PY="$CONDA_PY"
elif command -v python3 >/dev/null 2>&1; then
    PY=python3
elif command -v python >/dev/null 2>&1; then
    PY=python
else
    # No python — exit silently (cannot run hook).
    exit 0
fi

exec "$PY" "$REPO/run.py" "$@" || exit 0
