#!/usr/bin/env sh
# claude-hook — POSIX entry point for claude-hooks
#
# Usage:
#     claude-hook <EventName>
#
# Reads the hook event JSON from stdin, dispatches to the matching handler,
# and writes any response to stdout. Exits 0 on every code path so a broken
# hook never blocks Claude Code.
#
# This is a thin shim — all logic lives in run.py / claude_hooks/.

HERE="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$HERE/.." && pwd)"

# Resolve PY via the shared helper. Probes repo-local .venv (POSIX or
# Windows layout), then conda env, then system python.
. "$HERE/_resolve_python.sh"

# No python — exit silently. Hooks must never block Claude Code.
[ -z "$PY" ] && exit 0

exec "$PY" "$REPO/run.py" "$@" || exit 0
