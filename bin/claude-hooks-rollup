#!/bin/sh
# claude-hooks proxy rollup — uses the shared Python resolver.
HERE="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$HERE/.." && pwd)"
. "$HERE/_resolve_python.sh"
[ -z "$PY" ] && { echo "claude-hooks-rollup: no python found" >&2; exit 1; }
export PYTHONPATH="$REPO${PYTHONPATH:+:$PYTHONPATH}"
exec "$PY" "$REPO/scripts/proxy_rollup.py" "$@" || exit 0
