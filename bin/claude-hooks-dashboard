#!/bin/sh
# claude-hooks proxy dashboard — uses the shared Python resolver.
HERE="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$HERE/.." && pwd)"
. "$HERE/_resolve_python.sh"
[ -z "$PY" ] && { echo "claude-hooks-dashboard: no python found" >&2; exit 1; }
export PYTHONPATH="$REPO${PYTHONPATH:+:$PYTHONPATH}"
exec "$PY" -m claude_hooks.proxy.dashboard "$@" || exit 0
