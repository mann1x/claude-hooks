[Unit]
Description=Watch __HOME__/.claude.json and re-pin GrowthBook flags via claude-hooks-kairos-pin.service
Documentation=https://github.com/mann1x/claude-hooks/blob/main/claude_hooks/kairos_pin.py

[Path]
# install.py substitutes __HOME__ on install. PathModified fires on
# content rewrites (which is what the Claude Code CLI does on session
# start when it re-fetches GrowthBook). PathChanged would also fire on
# bare atime touches, which we don't care about.
PathModified=__HOME__/.claude.json
Unit=claude-hooks-kairos-pin.service

[Install]
WantedBy=multi-user.target
