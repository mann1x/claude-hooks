[Unit]
Description=claude-hooks proxy — local HTTP proxy in front of api.anthropic.com
Documentation=https://github.com/mann1x/claude-hooks/blob/main/docs/proxy.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# install.py substitutes __REPO_PATH__ and __HOME__ on install; edit
# here only if you manage the unit yourself.
User=root
WorkingDirectory=__REPO_PATH__
Environment=CLAUDE_HOOKS_REPO=__REPO_PATH__
ExecStart=__REPO_PATH__/bin/claude-hooks-proxy
Restart=on-failure
RestartSec=5s
# SIGTERM then SIGKILL — bounded stop even if a rogue SSE stream
# holds the server thread.
KillSignal=SIGTERM
TimeoutStopSec=10s
SendSIGKILL=yes

# Reasonable hardening — the proxy doesn't need privilege.
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=__HOME__/.claude
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
