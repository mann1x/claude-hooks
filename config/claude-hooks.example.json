{
  "version": 2,
  "_doc_claude_code_env_vars": [
    "This file configures claude-hooks itself, NOT Claude Code.",
    "Claude Code env vars go in ~/.claude/settings.json under 'env'.",
    "For the full curated reference with per-var verdicts see",
    "docs/env-vars.md. Quick summary of the most useful ones:",
    "",
    "  CLAUDE_CODE_DISABLE_BACKGROUND_TASKS=1",
    "    Recommended. Disables the subagent 'Warmup' drain that can",
    "    eat 99%+ of daily input tokens on plugin-heavy setups. See",
    "    issue #47922. Side-effect: also disables Ctrl+B and the Bash",
    "    tool's run_in_background parameter.",
    "",
    "  CLAUDE_CODE_AUTO_COMPACT_WINDOW=400000",
    "    Forces autocompact at 400k tokens. Recommended by bcherny",
    "    (Anthropic staff) if you feel Opus 4.6 degrades at large",
    "    contexts.",
    "",
    "  CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=75",
    "    Autocompact at 75% fill. Aggressive but useful for long",
    "    sessions.",
    "",
    "  CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING=1  +  MAX_THINKING_TOKENS=63999",
    "    bcherny-stack adaptive-thinking disable. We did NOT find it",
    "    helpful on this project (more trivial mistakes, slower",
    "    iteration). docs/env-vars.md has the long form.",
    "",
    "  ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-5-20251101",
    "    Pins Opus to 4.5 if you feel 4.6 regressed. We kept 4.6.",
    "",
    "  CLAUDE_CODE_DISABLE_1M_CONTEXT=1",
    "    Reverts Opus context to 200k. Big token saver on Max plans",
    "    but we rely on 1M for this codebase.",
    "",
    "Example settings.json env block (copy into ~/.claude/settings.json,",
    "NOT into this file):",
    "",
    "  {",
    "    \"env\": {",
    "      \"CLAUDE_CODE_DISABLE_BACKGROUND_TASKS\": \"1\"",
    "    }",
    "  }"
  ],
  "providers": {
    "qdrant": {
      "enabled": true,
      "mcp_url": "http://YOUR-HOST:32775/mcp",
      "headers": {},
      "collection": "memory",
      "recall_k": 5,
      "store_mode": "auto",
      "timeout": 5.0
    },
    "memory_kg": {
      "enabled": true,
      "mcp_url": "http://YOUR-HOST:32776/mcp",
      "headers": {},
      "recall_k": 5,
      "store_mode": "auto",
      "timeout": 5.0
    },
    "pgvector": {
      "enabled": false,
      "dsn": "postgresql://user:password@localhost:5432/memory",
      "table": "claude_hooks_memory",
      "embedder": "ollama",
      "embedder_options": {
        "url": "http://localhost:11434/api/embeddings",
        "model": "nomic-embed-text"
      },
      "recall_k": 5,
      "store_mode": "auto",
      "timeout": 10.0
    },
    "sqlite_vec": {
      "enabled": false,
      "db_path": "~/.claude/claude-hooks-memory.db",
      "table": "memory",
      "embedder": "ollama",
      "embedder_options": {
        "url": "http://localhost:11434/api/embeddings",
        "model": "nomic-embed-text"
      },
      "recall_k": 5,
      "store_mode": "auto",
      "timeout": 10.0
    }
  },
  "hooks": {
    "user_prompt_submit": {
      "enabled": true,
      "min_prompt_chars": 30,
      "include_providers": [
        "qdrant",
        "memory_kg"
      ],
      "max_total_chars": 4000,
      "hyde_enabled": false,
      "hyde_grounded": true,
      "hyde_ground_k": 3,
      "hyde_ground_max_chars": 1500,
      "hyde_model": "qwen3.5:2b",
      "hyde_fallback_model": "gemma4:e2b",
      "hyde_url": "http://localhost:11434/api/generate",
      "hyde_timeout": 30.0,
      "hyde_max_tokens": 150,
      "hyde_keep_alive": "15m",
      "progressive": false,
      "decay_enabled": false,
      "decay_file": "~/.claude/claude-hooks-decay.json",
      "decay_recency_halflife_days": 14,
      "decay_frequency_cap": 5
    },
    "session_start": {
      "enabled": true,
      "show_status_line": true,
      "compact_recall": true,
      "compact_recall_query": "session context, key decisions, and important patterns"
    },
    "stop": {
      "enabled": true,
      "store_threshold": "noteworthy",
      "classify_observations": true,
      "extract_instincts": false,
      "instincts_dir": "~/.claude/instincts"
    },
    "stop_guard": {
      "enabled": false,
      "patterns": [],
      "skip_meta_context": true,
      "meta_markers": [],
      "skip_on_user_wrap_up": true,
      "user_wrap_up_markers": []
    },
    "session_end": {
      "enabled": true
    },
    "claudemem_reindex": {
      "enabled": true,
      "check_on_stop": true,
      "check_on_session_start": true,
      "staleness_minutes": 10,
      "max_files_to_scan": 2000,
      "ignored_dirs": [],
      "lock_min_age_seconds": 60
    },
    "pre_tool_use": {
      "enabled": false,
      "warn_on_tools": [
        "Bash",
        "Edit",
        "Write"
      ],
      "warn_on_patterns": [
        "rm ",
        "DROP TABLE",
        "git reset --hard"
      ],
      "safety_scan_enabled": false,
      "safety_use_defaults": true,
      "safety_extra_patterns": [],
      "safety_log_enabled": true,
      "safety_log_dir": "~/.claude/permission-scanner",
      "safety_log_retention_days": 90,
      "rtk_rewrite_enabled": false,
      "rtk_min_version": "0.23.0",
      "rtk_timeout": 3.0,
      "rtk_log_rewrites": false,
      "rtk_scan_rewrites": true
    }
  },
  "reflect": {
    "enabled": true,
    "max_memories_to_analyze": 50,
    "min_pattern_count": 3,
    "output_path": "~/.claude/CLAUDE.md",
    "ollama_model": "gemma4:e2b",
    "ollama_url": "http://localhost:11434/api/generate"
  },
  "consolidate": {
    "enabled": false,
    "trigger": "manual",
    "min_sessions_between_runs": 10,
    "state_file": "~/.claude/claude-hooks-consolidate.json",
    "max_memories_to_scan": 200,
    "merge_similarity_threshold": 0.8,
    "prune_stale_days": 90,
    "ollama_model": "gemma4:e2b",
    "ollama_url": "http://localhost:11434/api/generate"
  },
  "episodic": {
    "mode": "off",
    "server_url": "",
    "server_host": "0.0.0.0",
    "server_port": 11435,
    "binary": "episodic-memory",
    "timeout": 10.0
  },
  "logging": {
    "path": "~/.claude/claude-hooks.log",
    "level": "info",
    "max_bytes": 2097152,
    "backup_count": 3
  },
  "disable_marker_filename": ".claude-hooks-disable"
}
